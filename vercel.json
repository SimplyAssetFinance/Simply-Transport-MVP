{
  "crons": [
    {
      "path": "/api/cron/scrape-tgp",
      "schedule": "0 20 * * 0-4"
    },
    {
      "path": "/api/send-reminders",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/reports/send?cadence=daily",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/reports/send?cadence=weekly",
      "schedule": "0 20 * * 1"
    },
    {
      "path": "/api/reports/send?cadence=monthly",
      "schedule": "0 20 1 * *"
    },
    {
      "path": "/api/reports/send?cadence=quarterly",
      "schedule": "0 20 1 1,4,7,10 *"
    },
    {
      "path": "/api/reports/send?cadence=annual",
      "schedule": "0 20 1 1 *"
    }
  ]
}
